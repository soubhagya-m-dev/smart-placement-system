# Copy to .env and fill in real values. NEVER commit the real .env.

# Server
PORT=5000
NODE_ENV=production

# Database
MONGODB_URI=

# Auth — REQUIRED. App will refuse to start if JWT_SECRET is missing.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRE=7d

# CORS — your deployed frontend origin. Used for both Express CORS and Socket.IO CORS.
FRONTEND_URL=https://your-frontend.example.com

# Firebase Admin SDK — paste the values from your Firebase service-account JSON.
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Email (optional — used by auth for password-reset flows)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# FROM_EMAIL=
